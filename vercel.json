{
  "version": 2,
  "functions": {
    "api/claude.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/signup.html", "dest": "/signup.html" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/confirm.html", "dest": "/confirm.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
  
